{
  "name": "cursala-private-api",
  "version": "1.1.0",
  "description": "cursala Private API",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch --env-file .env src/index.ts",
    "prod": "node ./dist/src/index.js",
    "start": "npm run prod",
    "build": "ts-node build.ts",
    "test": "jest --config=jest.config.js",
    "test:coverage": "jest --config=jest.config.js --coverage",
    "lint": "eslint src --cache --ext .ts --max-warnings 100",
    "lint:fix": "eslint src --cache --fix --ext .ts",
    "pre-commit": "lint-staged",
    "debug": "nodemon -e ts,tsx --exec node -r ts-node/register -r tsconfig-paths/register --inspect src/index.ts",
    "seed:dev-user": "tsx --env-file .env src/scripts/seed-dev-user.ts"
  },
  "repository": {},
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@types/sharp": "^0.31.1",
    "axios": "1.12.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-openapi-validator": "^5.6.0",
    "express-rate-limit": "^8.2.1",
    "express-winston": "4.2.0",
    "fs-extra": "^11.2.0",
    "googleapis": "^167.0.0",
    "helmet": "^8.1.0",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "mercadopago": "^2.11.0",
    "mongoose": "^9.0.1",
    "mongoose-paginate-v2": "^1.9.1",
    "ms": "^2.1.3",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.11",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.17.2",
    "puppeteer": "^24.32.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "svg-to-pdfkit": "^0.1.8",
    "uuid": "^13.0.0",
    "winston": "3.8.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/mongodb": "^4.0.7",
    "@types/multer": "^1.4.7",
    "@types/node": "^24.10.1",
    "@types/nodemailer": "^6.4.14",
    "@types/passport": "^1.0.13",
    "@types/passport-jwt": "^3.0.8",
    "@types/pdfkit": "^0.13.7",
    "@types/qrcode": "^1.5.5",
    "@types/supertest": "^2.0.16",
    "@types/uuid": "^9.0.7",
    "@types/validator": "^13.11.11",
    "@types/winston": "^2.4.4",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.1",
    "husky": "^9.0.11",
    "jest": "^30.3.0",
    "lint-staged": "^15.2.0",
    "nodemon": "^3.0.3",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "ts-node": "10.9.1",
    "tsc-alias": "^1.8.8",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^3.12.7",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{js,ts,css,md}": "prettier --write --no-error-on-unmatched-pattern --ignore-unknown",
    "*.ts": "npm run lint --"
  }
}
